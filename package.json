{
  "name": "@sannajammehtry/biome-style",
  "version": "0.0.1",
  "description": "Published coding style guides ported into Biome — formatter options, built-in lint rules, and GritQL plugins. First guide: Google TypeScript Style Guide.",
  "license": "MIT",
  "homepage": "https://github.com/sannajammeh/biome-style",
  "repository": {
    "type": "git",
    "url": "https://github.com/sannajammeh/biome-style.git"
  },
  "bugs": {
    "url": "https://github.com/sannajammeh/biome-style/issues"
  },
  "type": "module",
  "files": [
    "guides"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "./google-typescript": "./guides/google-typescript/biome.json",
    "./google-typescript/*": "./guides/google-typescript/*",
    "./airbnb-javascript": "./guides/airbnb-javascript/biome.json",
    "./airbnb-javascript/*": "./guides/airbnb-javascript/*"
  },
  "scripts": {
    "lint": "biome check .",
    "test": "bun test",
    "build:bundle": "bun scripts/build-bundle.ts",
    "prepublishOnly": "bun scripts/build-bundle.ts",
    "release": "GITHUB_TOKEN=\"${GITHUB_TOKEN:-$(gh auth token)}\" release-it"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/bun": "latest",
    "release-it": "^20.2.0"
  }
}
