// Airbnb JavaScript Style Guide — `new-parens`: always include parentheses when
// invoking a constructor, even with no arguments (`new Foo()`, not `new Foo`).
// `new Foo()` is a distinct CST node and is not matched here. Exact duplicate of
// the Google guide's `new-parens` (self-contained per ADR-0002).
language js

`new $callee` as $node where {
  register_diagnostic(span=$node, message="Constructor calls must use parentheses: write `new Foo()`, not `new Foo`.", severity="error")
}
